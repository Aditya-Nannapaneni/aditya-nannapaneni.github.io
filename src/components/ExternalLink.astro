---
interface Props {
  href: string;
  class?: string;
  external?: boolean;
}

const { href, class: className = '', external = false } = Astro.props;
const isExternal =
  external || href.startsWith('http') || href.startsWith('mailto:');
---

<a
  href={href}
  class={className}
  {...(isExternal
    ? {
        target: href.startsWith('mailto:') ? undefined : '_blank',
        rel: href.startsWith('mailto:') ? undefined : 'noopener noreferrer',
      }
    : {})}
>
  <slot />
</a>
