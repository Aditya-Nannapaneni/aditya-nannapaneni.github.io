---
interface Props {
  title?: string;
}

const { title = 'Note' } = Astro.props;
---

<aside class="border border-border bg-accent-soft/40 p-4 text-sm leading-6 text-ink-muted">
  <p class="font-mono text-xs uppercase tracking-wide text-ink-faint">{title}</p>
  <div class="mt-2">
    <slot />
  </div>
</aside>
