---
interface Props {
  href: string;
  title: string;
  summary: string;
  statusLabel?: string;
  tags: string[];
  keyLine?: string;
}

const { href, title, summary, statusLabel, tags, keyLine } = Astro.props;
---

<a
  href={href}
  class="group block border border-border bg-white p-6 no-underline transition-opacity hover:border-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
>
  <div class="flex items-start justify-between gap-4">
    <h3 class="text-lg font-semibold tracking-tight text-ink group-hover:underline">
      {title}
    </h3>
    {
      statusLabel && (
        <span class="status-pill shrink-0">{statusLabel}</span>
      )
    }
  </div>
  <p class="mt-3 text-sm leading-6 text-ink-muted">{summary}</p>
  {
    keyLine && (
      <p class="mt-4 border-l-2 border-accent pl-3 text-sm text-ink">{keyLine}</p>
    )
  }
  <ul class="mt-4 flex flex-wrap gap-x-3 gap-y-1">
    {
      tags.map((tag) => (
        <li class="tag">{tag}</li>
      ))
    }
  </ul>
  <p class="mt-5 text-sm text-accent">
    View case study <span aria-hidden="true">→</span>
  </p>
</a>
