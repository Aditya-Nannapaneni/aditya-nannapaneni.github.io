---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found — Aditya Nannapaneni" description="The requested page could not be found.">
  <section class="section-space">
    <div class="container-site max-w-[760px]">
      <h1 class="text-3xl font-semibold text-ink">Page not found</h1>
      <p class="mt-4 text-ink-muted">
        The page you requested does not exist or has moved.
      </p>
      <p class="mt-6">
        <a href="/" class="link-accent">Return home</a>
        <span class="mx-2 text-ink-faint">·</span>
        <a href="/archive" class="link-accent">View archive</a>
      </p>
    </div>
  </section>
</BaseLayout>
